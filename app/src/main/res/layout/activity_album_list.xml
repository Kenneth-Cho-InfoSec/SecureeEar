<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/app_bg_style"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:id="@+id/file_manager_top_bar"
        layout="@layout/app_top_bar"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/album_category_ll"
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:layout_below="@+id/file_manager_top_bar">
        <RelativeLayout
            android:id="@+id/ic_album_photo_rl"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <ImageView
                android:id="@+id/ic_album_photo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_album_photo_icon"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/ic_album_video_rl"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <ImageView
                android:id="@+id/ic_album_video"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_album_video_unselect"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/file_manager_no_data_saved"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="131dp"
        android:layout_below="@+id/file_manager_top_bar"
        android:layout_centerHorizontal="true">
        <ImageView
            android:layout_gravity="center_horizontal"
            android:id="@+id/file_manager_no_data_saved_image"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/ic_album_empty"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/apptextblack3"
            android:layout_gravity="center_horizontal"
            android:id="@+id/file_manager_no_data_saved_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/File_Label_FileList_Empty"/>
    </LinearLayout>
    <View
        android:id="@+id/file_manager_bottom_lines"
        android:background="@color/appblack"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_above="@+id/file_manager_bottom"/>
    <include
        android:id="@+id/file_manager_bottom"
        android:visibility="gone"
        layout="@layout/file_bottom_action"/>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/file_manager_bottom"
        android:layout_below="@+id/album_category_ll">
        <com.i4season.bkCamera.uirelated.other.view.stickygridheaders.StickyGridHeadersGridView
            android:id="@+id/file_manager_pic_timeline"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="9dp"
            android:layout_marginRight="9dp"
            android:horizontalSpacing="6dp"
            android:verticalSpacing="6dp"/>
    </FrameLayout>
</RelativeLayout>
