<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="45dp">
    <RelativeLayout
        android:id="@+id/app_topbar"
        android:layout_width="match_parent"
        android:layout_height="44dp">
        <RelativeLayout
            android:id="@+id/app_topbar_left"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:minWidth="44dp">
            <ImageView
                android:id="@+id/app_topbar_left_image"
                android:padding="12.5dp"
                android:visibility="gone"
                android:layout_width="44dp"
                android:layout_height="match_parent"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="16sp"
                android:textColor="@color/appblack"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/app_topbar_left_text2"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginLeft="14dp"
                android:layout_marginRight="60dp"
                android:maxLines="2"
                android:layout_toRightOf="@+id/app_topbar_left_image"/>
            <TextView
                android:textSize="16sp"
                android:textColor="@color/appblack"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/app_topbar_left_text"
                android:paddingLeft="5dp"
                android:paddingRight="5dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginLeft="14dp"
                android:maxWidth="100dp"
                android:maxLines="2"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/app_topbar_right"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true">
            <ImageView
                android:id="@+id/app_topbar_right_image"
                android:padding="11dp"
                android:visibility="visible"
                android:layout_width="44dp"
                android:layout_height="match_parent"
                android:layout_marginRight="5dp"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="16sp"
                android:textColor="@color/appblack"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/app_topbar_right_text"
                android:paddingLeft="5dp"
                android:paddingRight="5dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginRight="14dp"
                android:maxWidth="100dp"
                android:maxLines="2"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <ImageView
            android:id="@+id/app_topbar_right_image2"
            android:padding="11dp"
            android:visibility="gone"
            android:layout_width="44dp"
            android:layout_height="match_parent"
            android:layout_marginRight="1dp"
            android:layout_toLeftOf="@+id/app_topbar_right"
            android:layout_centerVertical="true"/>
        <ImageView
            android:id="@+id/app_topbar_right_image3"
            android:padding="11dp"
            android:visibility="gone"
            android:layout_width="44dp"
            android:layout_height="match_parent"
            android:layout_marginRight="1dp"
            android:layout_toLeftOf="@+id/app_topbar_right_image2"
            android:layout_centerVertical="true"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/appblack"
            android:gravity="center"
            android:id="@+id/app_topbar_center_text"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="60dp"
            android:layout_marginRight="60dp"
            android:maxWidth="150dp"
            android:text="标题"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <View
        android:id="@+id/app_bottom_line"
        android:background="@color/appblack"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"/>
</LinearLayout>
