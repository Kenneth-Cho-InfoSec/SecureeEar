<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/detail_mirror_ll"
    android:background="@color/appwhite"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/camera_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"/>
    <RelativeLayout
        android:id="@+id/camerashow_topbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp">
        <ImageView
            android:id="@+id/camerashow_back"
            android:padding="10dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginLeft="10dp"
            android:src="@drawable/ic_app_back_black"/>
        <ImageView
            android:id="@+id/camerashow_electricity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="20dp"
            android:src="@drawable/ic_charing_10"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="14dp"
            android:layout_marginRight="14dp"
            android:layout_toLeftOf="@+id/camerashow_electricity"
            android:layout_toRightOf="@+id/camerashow_back">
            <ImageView
                android:id="@+id/camerashow_screen_change"
                android:padding="10dp"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_screen_change"
                android:layout_weight="1"/>
            <RelativeLayout
                android:id="@+id/camerashow_screen_lock_rl"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/camerashow_screen_lock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_screen_lock"
                    android:layout_centerInParent="true"/>
            </RelativeLayout>
        </LinearLayout>
    </RelativeLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/camerashow_gyroscope_rl"
        android:background="@drawable/shape_white_stroke30"
        android:layout_width="250dp"
        android:layout_height="35dp"
        android:layout_marginTop="20dp"
        android:layout_below="@+id/camerashow_topbar"
        android:layout_centerHorizontal="true">
        <RelativeLayout
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@+id/gyroscope_on_rl"
            android:background="@drawable/shape_white_left_corner30"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <com.i4season.bkCamera.uirelated.other.view.VerticalTextView
                android:id="@+id/gyroscope_on_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="广屏镜头"
                app:text_color="@color/appwhite"
                app:text_size="16sp"/>
        </RelativeLayout>
        <View
            android:id="@+id/gyroscope_line1"
            android:background="@color/appline"
            android:visibility="gone"
            android:layout_width="0.5dp"
            android:layout_height="match_parent"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"/>
        <RelativeLayout
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@+id/gyroscope_off_rl"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <com.i4season.bkCamera.uirelated.other.view.VerticalTextView
                android:gravity="center"
                android:id="@+id/gyroscope_off_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="聚焦镜头"
                app:text_color="@color/apptextblack"
                app:text_size="16sp"/>
        </RelativeLayout>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/camerashow_function_rl_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <RelativeLayout
            android:id="@+id/photo_video_ll"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_centerHorizontal="true">
            <com.i4season.bkCamera.uirelated.other.view.BottomView
                android:id="@+id/photo_video_bv"
                android:layout_width="380dp"
                android:layout_height="match_parent"
                android:layout_alignParentBottom="true"/>
        </RelativeLayout>
        <LinearLayout
            android:id="@+id/bottom_ll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:layout_below="@+id/photo_video_ll">
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/camerashow_mirror_rl"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/camerashow_mirror_change"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_left_ear"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/apptextblack"
                    android:gravity="center"
                    android:id="@+id/camerashow_mirror_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="左右耳"
                    android:layout_below="@+id/camerashow_mirror_change"/>
            </LinearLayout>
            <RelativeLayout
                android:gravity="center"
                android:id="@+id/camerashow_take_photo_rl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/camerashow_take_photo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_take_photo"/>
            </RelativeLayout>
            <RelativeLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/camerashow_album_rl"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/camerashow_album_thumb"
                    android:visibility="gone"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerInParent="true"/>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true">
                    <ImageView
                        android:id="@+id/camerashow_album"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_album_icon"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/apptextblack"
                        android:gravity="center"
                        android:id="@+id/camerashow_album_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="相册"
                        android:layout_below="@+id/camerashow_album"/>
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
        <RelativeLayout
            android:id="@+id/camerashow_take_recode_ll"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:layout_above="@+id/bottom_ll"
            android:layout_centerHorizontal="true">
            <View
                android:id="@+id/camera_take_recode_dot"
                android:background="@drawable/red_dot"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="16dp"
                android:textColor="@color/apptextblack"
                android:id="@+id/camera_take_recode_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="3dp"
                android:text="00:00:00"
                android:layout_toRightOf="@+id/camera_take_recode_dot"/>
        </RelativeLayout>
    </RelativeLayout>
    <View
        android:id="@+id/camera_show_touch_hide"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/camerashow_function_rl_bottom"
        android:layout_below="@+id/camerashow_gyroscope_rl"/>
    <ImageView
        android:id="@+id/voice_switch"
        android:padding="10dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginRight="20dp"
        android:src="@drawable/ic_voice_close"
        android:layout_below="@+id/camerashow_gyroscope_rl"
        android:layout_alignParentRight="true"/>
</RelativeLayout>
