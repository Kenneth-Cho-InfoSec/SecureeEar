<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/shape_white_corner5"
    android:layout_width="250dp"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="16sp"
        android:textColor="@color/apptextblack"
        android:gravity="center"
        android:id="@+id/dialog_app_exit_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:text="@string/App_Exit_Title"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/apptextblack"
        android:gravity="center"
        android:id="@+id/dialog_app_exit_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/App_Exit_Title_Content"/>
    <include
        android:id="@+id/dialog_bottom_button"
        layout="@layout/base_dialog"/>
</LinearLayout>
