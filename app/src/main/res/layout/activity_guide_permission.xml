<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/guide_permission_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/guide_permission_img"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="80dp"
        android:layout_alignParentBottom="true">
        <TextView
            android:textSize="18sp"
            android:textColor="@color/apptextblack"
            android:gravity="center"
            android:id="@+id/guide_permission_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="允许语音权限"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/apptextblack2"
            android:gravity="center"
            android:id="@+id/guide_permission_point"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="50dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="50dp"
            android:text="需要接收语音信息，才能帮您进行语音控制"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/appwhite"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:id="@+id/guide_permission_next"
            android:background="@drawable/shape_takeaction_corner5"
            android:layout_width="150dp"
            android:layout_height="40dp"
            android:layout_marginTop="50dp"
            android:text="下一步"/>
    </LinearLayout>
</RelativeLayout>
