<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:background="@color/apptakeaction"
    android:layout_width="match_parent"
    android:layout_height="50dp">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="50dp">
        <TextView
            android:textSize="14sp"
            android:textColor="@color/apptextblack"
            android:id="@+id/ws_listchoose_item_titletv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="asdasdasd"/>
        <TextView
            android:textColor="@color/apptopbgcolor"
            android:id="@+id/ws_listchoose_item_infotv"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"/>
    </LinearLayout>
    <View
        android:id="@+id/view1"
        android:layout_width="wrap_content"
        android:layout_height="54dp"
        android:layout_weight="1"/>
    <LinearLayout
        android:gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="match_parent">
        <ImageView
            android:id="@+id/ws_listchoose_item_selectiv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="20dp"
            android:src="@drawable/ic_language_select"/>
    </LinearLayout>
</LinearLayout>
