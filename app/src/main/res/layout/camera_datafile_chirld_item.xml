<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:fresco="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="90dp"
    android:layout_height="80dp">
    <ImageView
        android:id="@+id/camera_data_thumb"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:scaleType="fitCenter"/>
    <ImageView
        android:id="@+id/camera_data_mask"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:src="#00000000"
        android:scaleType="centerCrop"/>
    <ImageView
        android:id="@+id/camera_data_select"
        android:visibility="visible"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginTop="5dp"
        android:layout_marginRight="5dp"
        android:src="@drawable/ic_file_select"
        android:layout_alignParentRight="true"
        android:contentDescription="@null"/>
    <TextView
        android:textSize="12dp"
        android:textColor="@color/appwhite"
        android:id="@+id/camera_video_data_time"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="7dp"
        android:layout_marginBottom="5dp"
        android:text="10 : 25"
        android:layout_alignParentBottom="true"
        android:layout_alignEnd="@+id/camera_data_thumb"/>
    <ImageView
        android:id="@+id/camera_video_icon"
        android:paddingBottom="2.5dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:src="@drawable/ic_album_video_small_icon"
        android:layout_alignParentBottom="true"
        android:layout_alignStart="@+id/camera_data_thumb"/>
</RelativeLayout>
